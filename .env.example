# Archetype AI platform credentials
ATAI_API_KEY=sk_...
ATAI_API_ENDPOINT=https://api.u1.archetypeai.app

# Tag appended to uploaded file_ids (platform file_ids are immutable). Must match
# what the committed data/subset was uploaded under.
FILE_SUFFIX=_g

# Fine-tune random seed. Defaults to 0 (a strong seed in our sweep). Override to
# explore seed variance, or pin to reproduce a specific run.
# OMEGA_FT_SEED=0

# Optional: subsample eval windows to speed inference (1 = densest / most accurate).
# EVAL_STEP=1

# Optional pins (normally auto-resolve; set only if a 404 forces it):
# MSJ_PIPELINE_VERSION=...
# OMEGA_FT_PIPELINE_VERSION=...

# Optional: override the Omega 1.5 encoder the worker loads. The shared marketplace
# depot path below works across environments (dev/stage/prod); leave unset to use the
# pipeline's own default.
# OMEGA_15_BASE_MODEL_PATH=s3://atai-marketplace-model-depot/omega/1.5/model.pt
